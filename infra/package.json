{
  "name": "bt-infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "bt": "bin/bt.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:phase1": "cdk deploy BtSecurity BtData BtObservability --require-approval never",
    "deploy:phase2": "cdk deploy BtAuth --require-approval never",
    "deploy:phase3": "cdk deploy BtApi --require-approval never",
    "deploy:phase4": "cdk deploy BtSpa --require-approval never",
    "destroy": "cdk destroy --all"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "aws-cdk": "2.1118.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  },
  "dependencies": {
    "aws-cdk-lib": "2.177.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  }
}
