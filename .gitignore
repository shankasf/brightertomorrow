# Secrets — never commit
.env
.env.local
.env.*.local
*.env
ai/.env
web/.env.local
gateway/.env

# k8s secret manifests — use 10-secrets.example.yaml as the template
k8s/10-secrets.yaml

# Node
**/node_modules/
web/.next/
web/out/
web/.turbo/
web/coverage/
web/*.tsbuildinfo
admin-spa/.next/
admin-spa/out/
admin-spa/*.tsbuildinfo

# Python
**/__pycache__/
ai/.venv/
ai/venv/
ai/*.pyc
ai/.pytest_cache/

# Go — binaries and test cache
gateway/out/
gateway/*.exe
gateway/*.test

# Docker
**/.dockerignore.bak

# OS
.DS_Store
Thumbs.db

# Local log dumps
BT.TXT
*.log

# CDK
infra/node_modules/
infra/cdk.out/
infra/cdk.out.obs/
infra/.cdk.staging/
infra/*.d.ts
infra/*.js
!infra/jest.config.js

# IDE / AI tooling
.claude/
.vscode/
.idea/
image.png

# Sensitive binaries — never commit contracts, intake templates, PHI
*.pdf
*.xlsx
*.xls
*.docx
*.doc
*.csv

# Exception: public marketing freebies on /services/journal (NOT PHI),
# versioned via Git LFS. Keep this scoped to web/public/downloads only.
!web/public/downloads/*.pdf
!web/public/downloads/*.docx
